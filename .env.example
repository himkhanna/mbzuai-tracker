# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=8h

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mbzuai_tracker

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@mbzuai.ac.ae
SMTP_PASS=your_app_password
EMAIL_FROM=MBZUAI Tracker <notifications@mbzuai.ac.ae>

# App
CLIENT_URL=http://localhost:5173
APP_NAME=MBZUAI Delivery Tracker

# Cron
ENABLE_CRON_JOBS=true
CRON_TIMEZONE=Asia/Dubai

# Oracle PO Email Ingestion (IMAP)
ENABLE_EMAIL_INGESTION=false
IMAP_HOST=imap.mbzuai.ac.ae
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=receiver@mbzuai.ac.ae
IMAP_PASS=your_imap_password
IMAP_POLL_INTERVAL=10
